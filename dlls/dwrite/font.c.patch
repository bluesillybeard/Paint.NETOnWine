+// Surely should not be in this file. or there is a better alternative ?
+// but this work so
+// Note: this is to avoid crash on paint.net 5. easily replicable by hovering over the toolbox and moving the mouse
+static void addSafe(LONG* pos, INT value) {
+    LONG current = *pos;
+    LONG result = current + (LONG)value;
+    TRACE("somehow, this is needed ? optimization issue ?\n");
+    if ((value > 0) && (current > result)) {
+        *pos = LONG_MAX;
+    }
+    else if ((value < 0) && (current < result)) {
+        *pos = LONG_MIN;
+    }
+    else *pos = result;
+}
+
+static void OffsetRectSafe(RECT* rect, INT x, INT y) {
+    addSafe(&rect->left, x);
+    addSafe(&rect->right, x);
+    addSafe(&rect->top, y);
+    addSafe(&rect->bottom, y);
+}
